# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/agentguard

# Redis
REDIS_URL=redis://localhost:6379

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Dodo Payments
# API Key from https://dashboard.dodopayments.com
DODO_API_KEY=your_dodo_api_key
DODO_SECRET_KEY=your-dodo-secret-key
DODO_WEBHOOK_SECRET=your-dodo-webhook-secret

# DODO Product IDs (already configured in app/services/dodo_payments.py)
# Monthly Plans
DODO_PRODUCT_STARTER_MONTHLY=pdt_0NWy24agfZczLQITzzA8i
DODO_PRODUCT_PRO_MONTHLY=pdt_0NWy2Alvj6LyAQ2yxnPEX
DODO_PRODUCT_TEAM_MONTHLY=pdt_0NWy2JXouiw6U0Ujnrhpm
# Annual Plans
DODO_PRODUCT_STARTER_ANNUAL=pdt_0NWy2oy0esfnTlMBXv2d1
DODO_PRODUCT_PRO_ANNUAL=pdt_0NWy31GCpUrIO62rldxCD
DODO_PRODUCT_TEAM_ANNUAL=pdt_0NWy3DgqaG2ofherN7Pm3

# Configure webhook: https://api.yourdomain.com/v1/webhooks/dodo

# Email Service (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@agentguard.ai
FROM_NAME=AgentGuard

# SendGrid (alternative)
SENDGRID_API_KEY=your-sendgrid-key

# App URL (for email links and payment redirects)
APP_URL=http://localhost:3000

# Environment
ENVIRONMENT=development
DEBUG=True
